<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>2048</title>
<style>
  :root {
    --board-size: min(92vmin, 520px);
    --gap: 12px;
    --tiles: 4;
    --cell-size: calc((var(--board-size) - (var(--tiles) + 1) * var(--gap)) / var(--tiles));
    --bg: #faf8ef;
    --board-bg: #bbada0;
    --cell-bg: #cdc1b4;
    --text-dark: #776e65;
    --text-light: #f9f6f2;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: var(--bg);
    color: var(--text-dark);
    font: 16px/1.25 -apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
  }
  .game {
    width: min(96vw, 560px);
    display: grid;
    gap: 14px;
  }
  .header {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  h1 {
    margin: 0;
    font-size: 42px;
    letter-spacing: 1px;
  }
  .spacer { flex: 1; }
  .scorebox {
    background: #bbada0;
    color: white;
    border-radius: 6px;
    padding: 8px 12px;
    text-align: center;
    min-width: 96px;
  }
  .scorebox small { display: block; font-size: 11px; opacity: .9; letter-spacing: .5px; }
  .scorebox b { display: block; font-size: 20px; margin-top: 2px; }
  button {
    background: #8f7a66;
    color: #fff;
    border: 0;
    border-radius: 6px;
    padding: 10px 14px;
    font-weight: 700;
    cursor: pointer;
  }
  button:active { transform: translateY(1px); }
  .board-wrap {
    position: relative;
    width: var(--board-size);
    height: var(--board-size);
    margin-inline: auto;
  }
  .board {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(4, var(--cell-size));
    grid-template-rows: repeat(4, var(--cell-size));
