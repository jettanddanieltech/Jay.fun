<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>2048 // OMNI_EDITION</title>
    <style>
        :root { 
            --bg: #000; --blue: #33BBFF; --green: #00FF41; 
            --panel: #0a0a0a; --text: #fff; --border: #111; --tile: #111;
        }
        body.light-mode { 
            --bg: #f4f4f4; --blue: #0077ff; --green: #008800; 
            --panel: #fff; --text: #000; --border: #ddd; --tile: #eee;
        }

        body { 
            background: var(--bg); color: var(--text); 
            font-family: 'Inter', sans-serif; margin: 0; 
            overflow: hidden; transition: 0.3s;
        }

        /* --- UI OVERLAYS --- */
        .overlay {
            position: fixed; inset: 0; background: var(--bg);
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; z-index: 1000;
        }

        .logo { 
            font-size: 80px; font-weight: 900; color: var(--blue); 
            text-shadow: 0 0 20px rgba(51, 187, 255, 0.3);
            margin-bottom: 40px; letter-spacing: -4px;
        }

        .menu-btn {
            background: var(--panel); border: 1px solid var(--blue);
            color: var(--blue); padding: 15px 40px; border-radius: 50px;
            cursor: pointer; font-weight: bold; margin: 10px;
            width: 250px; transition: 0.2s; text-transform: uppercase;
        }
        .menu-btn:hover { background: var(--blue); color: #000; box-shadow: 0 0 20px var(--blue); }

        /* --- GAME HUD --- */
        #game-hud {
            position: absolute; top: 0; width: 100%; padding: 25px;
            display: flex; justify-content: space-around;
            font-family: monospace; color: var(--green); z-index: 50;
            opacity: 0; transition: 0.5s; font-size: 18px;
        }

        /* --- 2048 ENGINE STYLES --- */
        #game-area {
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; height: 100vh; opacity: 0; transition: 0.8s;
        }

        .grid { 
            display: grid; grid-template-columns: repeat(4, 90px); 
            grid-template-rows: repeat(4, 90px); gap: 12px; 
            background: var(--panel); padding: 15px; border-radius: 12px;
            border: 1px solid var(--border);
        }

        .tile { 
            width: 90px; height: 90px; background: var(--tile); 
            border-radius: 8px; display: flex; align-items: center; 
            justify-content: center; font-size: 28px; font-weight: bold; 
            border: 1px solid var(--border); transition: 0.1s;
        }

        .tile[data-val="2"] { color: var(--text); }
        .tile[data-val="4"] { color: var(--blue); }
        .tile[data-val="8"] { color: var(--green); text-shadow: 0 0 10px var(--green); }
        .tile[data-val="16"] { color: #FF00FF; }
        .tile[data-val="32"] { color: #FFFF00; }
        .tile[data-val="64"] { color: #FF4500; }
        .tile[data-val="128"], .tile[data-val="256"], .tile[data-val="512"] { box-shadow: inset 0 0 15px var(--blue); }
        .tile[data-val="1024"], .tile[data-val="2048"] { background: var(--blue); color: #000; box-shadow: 0 0 30px var(--blue); }

        .hidden { display: none !important; }
    </style>
</head>
<body>

<div id="main-menu" class="overlay">
    <div class="logo">2048 // <span>OMNI</span></div>
    <button class="menu-btn" onclick="initGame()">Start Neural Link</button>
    <button class="menu-btn" onclick="toggleSettings(true)">Settings</button>
    <button class="menu-btn" onclick="window.location.href='index.html'">Exit to Hub</button>
</div>

<div id="settings-menu" class="overlay hidden">
    <div style="background: var(--panel); padding: 40px; border-radius: 20px; border: 1px solid var(--border); text-align: center;">
        <h2 style="color:var(--blue)">SYSTEM_CONFIG</h2>
        <button class="menu-btn" onclick="toggleTheme()">Toggle Dark/Light</button>
        <button class="menu-btn" onclick="toggleSettings(false)" style="border-color:var(--green); color:var(--green)">Apply & Close</button>
    </div>
</div>

<div id="game-hud">
    <span>NODE: 2048_CORE</span>
    <span>SCORE: <span id="score">0</span></span>
    <span onclick="location.reload()" style="cursor:pointer; border: 1px solid var(--green); padding: 2px 10px;">REBOOT</span>
</div>

<div id="game-area">
    <div class="grid" id="grid"></div>
    <p style="margin-top:20px; font-size:10px; color:#444; letter-spacing:2px;">WASD OR ARROWS TO SHIFT DATA</p>
</div>

<script>
    const gridDisplay = document.getElementById('grid');
    const scoreDisplay = document.getElementById('score');
    let score = 0;
    let squares = [];

    // --- UI LOGIC ---
    function toggleSettings(show) {
        document.getElementById('settings-menu').classList.toggle('hidden', !show);
    }

    function toggleTheme() {
        document.body.classList.toggle('light-mode');
        localStorage.setItem('omni_theme', document.body.classList.contains('light-mode') ? 'light' : 'dark');
    }

    function initGame() {
        document.getElementById('main-menu').classList.add('hidden');
        document.getElementById('game-hud').style.opacity = "1";
        document.getElementById('game-area').style.opacity = "1";
        createBoard();
        document.addEventListener('keyup', control);
    }

    // --- 2048 ENGINE ---
    function createBoard() {
        for (let i = 0; i < 16; i++) {
            let square = document.createElement('div');
            square.className = 'tile';
            square.setAttribute('data-val', '0');
            gridDisplay.appendChild(square);
            squares.push(square);
        }
        generate(); generate();
    }

    function generate() {
        let empty = squares.filter(s => s.innerHTML === '');
        if (empty.length > 0) {
            let randomSquare = empty[Math.floor(Math.random() * empty.length)];
            let val = Math.random() > 0.1 ? 2 : 4;
            randomSquare.innerHTML = val;
            randomSquare.setAttribute('data-val', val);
            checkForGameOver();
        }
    }

    function control(e) {
        if (e.key === 'ArrowRight' || e.key === 'd') { move('right'); }
        else if (e.key === 'ArrowLeft' || e.key === 'a') { move('left'); }
        else if (e.key === 'ArrowUp' || e.key === 'w') { move('up'); }
        else if (e.key === 'ArrowDown' || e.key === 's') { move('down'); }
    }

    function move(dir) {
        let prevBoard = squares.map(s => s.innerHTML);
        if (dir === 'right' || dir === 'left') moveHorizontal(dir);
        else moveVertical(dir);
        
        combine(dir);
        
        if (dir === 'right' || dir === 'left') moveHorizontal(dir);
        else moveVertical(dir);

        if (squares.map(s => s.innerHTML).join(',') !== prevBoard.join(',')) generate();
    }

    function moveHorizontal(dir) {
        for (let i = 0; i < 16; i += 4) {
            let row = [parseInt(squares[i].innerHTML)||0, parseInt(squares[i+1].innerHTML)||0, parseInt(squares[i+2].innerHTML)||0, parseInt(squares[i+3].innerHTML)||0];
            let filtered = row.filter(n => n);
            let result = dir === 'right' ? Array(4 - filtered.length).fill(0).concat(filtered) : filtered.concat(Array(4 - filtered.length).fill(0));
            for (let j = 0; j < 4; j++) {
                squares[i+j].innerHTML = result[j] || '';
                squares[i+j].setAttribute('data-val', result[j] || '0');
            }
        }
    }

    function moveVertical(dir) {
        for (let i = 0; i < 4; i++) {
            let col = [parseInt(squares[i].innerHTML)||0, parseInt(squares[i+4].innerHTML)||0, parseInt(squares[i+8].innerHTML)||0, parseInt(squares[i+12].innerHTML)||0];
            let filtered = col.filter(n => n);
            let result = dir === 'down' ? Array(4 - filtered.length).fill(0).concat(filtered) : filtered.concat(Array(4 - filtered.length).fill(0));
            for (let j = 0; j < 4; j++) {
                squares[i+(j*4)].innerHTML = result[j] || '';
                squares[i+(j*4)].setAttribute('data-val', result[j] || '0');
            }
        }
    }

    function combine(dir) {
        // Simple merge logic for rows/cols
        for (let i = 0; i < 15; i++) {
            if (squares[i].innerHTML !== '' && squares[i].innerHTML === squares[i+1].innerHTML && (i+1)%4 !== 0) {
                let val = parseInt(squares[i].innerHTML) * 2;
                squares[i].innerHTML = val;
                squares[i].setAttribute('data-val', val);
                squares[i+1].innerHTML = '';
                score += val;
                scoreDisplay.innerHTML = score;
            }
        }
    }

    function checkForGameOver() {
        if (!squares.some(s => s.innerHTML === '')) alert('NODE SATURATION: Game Over');
    }

    window.onload = () => {
        if (localStorage.getItem('omni_theme') === 'light') document.body.classList.add('light-mode');
    };
</script>
</body>
</html>
